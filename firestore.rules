rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             (!('email' in data) || data.email is string) &&
             (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string) &&
             (!('specialty' in data) || data.specialty is string) &&
             (!('hospital' in data) || data.hospital is string) &&
             (!('isProfileComplete' in data) || data.isProfileComplete is bool);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true; // Temporary for debugging/setup
      allow write: if isOwner(userId);
    }
  }
}
